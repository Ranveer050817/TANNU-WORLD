{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Store product",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" },
        "status": { "type": "string" }
      },
      "required": ["name", "price", "category", "status"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": "Product",
      "description": "Main catalogue of products"
    }
  }
}
