rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isAdmin() {
      return request.auth != null && 
        (request.auth.token.email == 'ranveerkumar2753@gmail.com' || 
         exists(/databases/$(database)/documents/admins/$(request.auth.uid)));
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'price', 'category', 'status'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 100
        && data.price is string && data.price.size() > 0 && data.price.size() <= 50
        && data.category is string && data.category.size() > 0 && data.category.size() <= 50
        && data.status is string && data.status.size() > 0 && data.status.size() <= 50
        && (!data.keys().hasAny(['description']) || (data.description is string && data.description.size() <= 2000))
        && (!data.keys().hasAny(['image']) || (data.image is string));
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow delete: if isAdmin() && isValidId(productId);
    }
    
    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if false; // Only manageable from DB console
    }
  }
}
